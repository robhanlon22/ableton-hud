{
  "name": "aosc-hud",
  "version": "0.1.0",
  "description": "Always-on-top AbletonOSC clip timing HUD",
  "main": "out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dist:mac": "npm run build && electron-builder --mac dir"
  },
  "build": {
    "appId": "com.rob.aosc.hud",
    "productName": "AOSC HUD",
    "mac": {
      "target": [
        "dir"
      ],
      "identity": null,
      "category": "public.app-category.music"
    },
    "files": [
      "out/main/**/*",
      "out/preload/**/*",
      "out/renderer/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "osc": "^2.4.5",
    "zod": "^4.1.11"
  }
}
