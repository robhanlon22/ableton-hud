{
  "name": "ableton-hud",
  "version": "0.1.0",
  "description": "Always-on-top Ableton Live clip timing HUD",
  "main": "out/main/index.js",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:debug": "sh ./scripts/dev-debug.sh",
    "build": "electron-vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "preview": "electron-vite preview",
    "test": "vitest run --coverage",
    "test:e2e": "pnpm run build && playwright test -c playwright.electron.config.ts",
    "test:e2e:headed": "pnpm run build && playwright test -c playwright.electron.config.ts --headed",
    "typecheck": "tsc --noEmit",
    "dist:mac": "pnpm run build && electron-builder --mac dir --universal",
    "dist:win": "pnpm run build && electron-builder --win nsis --x64 --publish never"
  },
  "build": {
    "appId": "com.sketch-artist.ableton-hud",
    "productName": "Ableton HUD",
    "mac": {
      "target": [
        "dir"
      ],
      "identity": null,
      "category": "public.app-category.music"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "out/main/**/*",
      "out/preload/**/*",
      "out/renderer/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-sonarjs": "^4.0.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "ableton-live": "^12.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
